rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // EVENTS — everyone can read, only admins can write
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // BOOKINGS — authenticated users can create, only the booking owner or admin can read
    match /bookings/{bookingId} {
      allow create: if true; // Allow unauthenticated booking (guest checkout)
      allow read: if request.auth != null &&
        (resource.data.email == request.auth.token.email || isAdmin(request.auth.token.email));
      allow update: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // NEWSLETTER — anyone can subscribe, only admins can read
    match /newsletter/{docId} {
      allow create: if true;
      allow read: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // BLOG — everyone can read, only admins can write
    match /blog/{postId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // MEMBERS — admins manage, users can read their own
    match /members/{memberId} {
      allow read: if request.auth != null &&
        (resource.data.email == request.auth.token.email || isAdmin(request.auth.token.email));
      allow write: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // USERS — users can read/write their own profile, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin(request.auth.token.email));
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // OTP CODES — only accessible via Admin SDK (serverless functions)
    // No client-side access allowed for security
    match /otp_codes/{email} {
      allow read, write: if false;
    }

    // Helper: check if user is admin
    // Replace with YOUR admin email(s)
    function isAdmin(email) {
      return email in ['tuaemail@ebberesi.it'];
    }
  }
}
