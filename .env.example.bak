# Firebase
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Firebase Admin (for serverless functions — these go in Vercel env vars)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Gmail SMTP (for OTP emails)
GMAIL_USER=tuaemail@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop

# Stripe (publishable key only — secret key goes in Vercel env vars)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# PayPal
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

# Satispay
VITE_SATISPAY_PUBLIC_KEY=your_satispay_key
